<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fichier conservé pour référence IDE / historique.
  Le logback utilisé au runtime et embarqué dans le jar est : src/resources/logback.xml
-->
<configuration>
    <!-- Configuration des propriétés -->
    <property name="LOG_DIR" value="Logs"/>
    <!-- Variable d'environnement optionnelle: APP_LOG_LEVEL (ex: DEBUG, INFO, WARN) -->
    <property name="APP_LOG_LEVEL" value="${APP_LOG_LEVEL:-INFO}"/>
    <property name="LOG_PATTERN" value="%d{HH:mm:ss.SSS} | %clr(%-5level){FATAL=1;31, ERROR=31, WARN=33, INFO=32, DEBUG=36, TRACE=35} | %logger{36} - %msg%n"/>

    <!-- Appender Console avec couleurs ANSI -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.out</target>
        <immediateFlush>true</immediateFlush>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Appender Console stderr pour les erreurs -->
    <appender name="CONSOLE_ERROR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <immediateFlush>true</immediateFlush>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %highlight(%-5level){FATAL=\u001B[1;31m, ERROR=\u001B[31m} | %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Appender Fichier Rolling pour tous les logs -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/server.log</file>
        <immediateFlush>true</immediateFlush>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %-5level | %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/server-%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>300MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Appender Fichier pour les erreurs uniquement -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/errors.log</file>
        <immediateFlush>true</immediateFlush>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %-5level | %logger{36} - %msg%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/errors-%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <maxFileSize>5MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Appender Fichier pour AI Profiling -->
    <!-- immediateFlush=true = écriture immédiate chaque log (pas de buffering) pour éviter la perte de données -->
    <appender name="AI_PROFILING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/AIProfiling/ai_profiling.log</file>
        <immediateFlush>true</immediateFlush>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %-5level | %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/AIProfiling/ai_profiling-%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Logger root dynamique via APP_LOG_LEVEL (fallback INFO) -->
    <root level="${APP_LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONSOLE_ERROR"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- Loggers spécifiques pour les packages StarLoco -->
    <logger name="org.starloco.locos" level="${APP_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONSOLE_ERROR"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Logger pour le kernel -->
    <logger name="org.starloco.locos.kernel" level="${APP_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONSOLE_ERROR"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Libraries bruyantes -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.apache.mina.filter.codec.ProtocolCodecFilter" level="WARN"/>

    <!-- Logger pour la base de données -->
    <logger name="org.starloco.locos.database" level="${APP_LOG_LEVEL}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONSOLE_ERROR"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- Logger spécifique pour AI Profiling (ne écrit QUE dans le fichier AIProfiling) -->
    <logger name="ai.profiling" level="DEBUG" additivity="false">
        <appender-ref ref="AI_PROFILING_FILE"/>
    </logger>

    <!-- Shutdown hook: flush tous les logs à l'arrêt du serveur -->
    <shutdownHook class="ch.qos.logback.core.hook.DelayingShutdownHook">
        <!-- Attendre max 10 secondes avant de forcer l'arrêt (permet le flush des buffers) -->
        <delay>10000</delay>
    </shutdownHook>

</configuration>


